{
  "name": "agent-canvas",
  "version": "1.1.1-dev",
  "description": "Agent Canvas — master-stack supervision for coding agent fleets",
  "main": "./out/main/index.js",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n remote,app -c blue,green \"vite build -c vite.remote.config.ts --watch\" \"electron-vite dev\"",
    "build": "electron-vite build && npm run build:remote",
    "build:remote": "vite build -c vite.remote.config.ts",
    "dist": "Packaging/package.sh",
    "postinstall": "patch-package && electron-rebuild -f -w node-pty",
    "typecheck": "tsc --noEmit",
    "orchestrator:harness": "tsx src/main/orchestrator/harness.ts",
    "mastermind:edges": "tsx src/main/mastermind/edges.ts",
    "mastermind:learn": "tsx src/main/mastermind/learn-smoke.ts",
    "mastermind:live": "tsx src/main/mastermind/live-smoke.ts",
    "mastermind:operator": "tsx src/main/mastermind/operator-smoke.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.178",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@hugeicons/core-free-icons": "^4.2.0",
    "@hugeicons/react": "^1.1.6",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-slot": "^1.2.5",
    "@tabler/icons-react": "^3.44.0",
    "electron-updater": "^6.8.9",
    "node-pty": "^1.0.0",
    "web-push": "^3.6.7",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@base-ui/react": "^1.5.0",
    "@electron/rebuild": "^3.7.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^10.0.3",
    "electron": "^34.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^3.0.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.18.0",
    "patch-package": "^8.0.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reekko1/agent-canvas.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/reekko1/agent-canvas/issues"
  },
  "homepage": "https://github.com/reekko1/agent-canvas#readme"
}
